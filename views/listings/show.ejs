<% layout('layouts/boilerplate') -%>

    <div class="row mt-3">
        <div class="col-8 offset-3">
            <h3>
                <%= listings.title %>
            </h3>
        </div>
        <div class="card col-6 offset-3 show-card listing-card">
            <img src="<%= listings.image %>" class="card-img-top show-img" alt="Listing-Image" <div class="card-body">
            <p class="card-text">
                <!-- <b><%= listings.title %></b> -->
                <br>
                <%= listings.description %> <br>
                    &#8377; <%= Number(listings.price).toLocaleString("en-IN") %> <br>
                        <%= listings.location %> <br>
                            <%= listings.country %>
            </p>
        </div>

        <div class="btns mb-3">
            <a href="/listings/<%= listings._id %>/edit" class="btn btn-dark col-1 offset-3 edit-btn">Edit</a><br>
            <form action="/listings/<%= listings._id %>?_method=DELETE" method="post">
                <button class="btn btn-dark offset-5">Delete</button>
            </form>
        </div>

        <div class=" col-8 offset-3 mb-3">
            <hr />
            <h4>Leave a Review</h4>
            <form action="/listings/<%= listings._id %>/reviews" method="post" novalidate class="needs-validation">
                <div class="mb-3 mt-3">
                    <label for="rating" class="form-label">Rating</label>
                    <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range">
                </div>

                <div class="mb-3 mt-3">
                    <label for="comment" class="form-label">Comments</label>
                    <textarea name="review[comment]" id="comment" cols="30" rows="4" class="form-control"
                        required></textarea>
                    <div class="invalid-feedback">Please add some comments for review.</div>
                </div>


                <button class="btn btn-outline-dark">Submit</button>
            </form>

            <hr />

            <!-- <h4>All Reviews</h4>
            <ul>
                <% for(review of listings.reviews) { %>
                    <li><%= review.rating %> , <%= review.comment %></li>
                <% } %>
            </ul> -->

            <p><b>All Reviews</b></p>
            <div class="row">
                <% for(review of listings.reviews) { %>
                    <div class="card col-5 ms-3 mb-3">
                        <div class="card-body">
                            <h5 class="card-title">SwarajRaj </h5>
                            <p class="card-text">
                                <%= review.comment %>
                            </p>
                            <p class="card-text">
                                <%= review.rating %> Starts
                            </p>
                        </div>
                        <form action="/listings/<%= listings._id %>/reviews/<%= review._id %>?_method=DELETE" class="mb-3" method="post">
                            <button class="btn btn-sm btn-dark">Delete</button>
                        </form>
                    </div>
                    <% } %>
            </div>


        </div>

    </div>
    <script src="/js/script.js"></script>